# .gitignore
# Ignore macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Ignore editor directories and files
.idea/
.vscode/
*.swp
*.swo

# Ignore builds and packages
*.zip
*.tar.gz
*.rar
node_modules/
dist/
build/

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files
.env
.env.local
